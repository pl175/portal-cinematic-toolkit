{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/**/*.ts",
    "bf6/types/**/*.d.ts"
  ]
}